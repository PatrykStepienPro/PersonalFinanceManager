{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Secret": "PFM_Super_Secret_Key_That_Is_Long_Enough_32chars!",
    "Issuer": "PFM.AuthService",
    "Audience": "PFM.Client"
  },

  "ReverseProxy": {
    "Routes": {
      "transactions-route": {
        "ClusterId": "transaction-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        }
      },
      "categories-route": {
        "ClusterId": "transaction-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "budgets-route": {
        "ClusterId": "budgets-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/budgets/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "transaction-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5087"
          }
        }
      },
      "budgets-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      }
    }
  },
  
  "AllowedHosts": "*"
}
